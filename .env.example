# Copy to .env.local and fill in. Do not commit .env.local.

# LiveKit (required for worker)
LIVEKIT_URL=
LIVEKIT_API_KEY=
LIVEKIT_API_SECRET=

# Providers (match src/hooks/session.py pipeline)
OPENAI_API_KEY=
DEEPGRAM_API_KEY=
INWORLD_API_KEY=

# Cal.com booking
CALCOM_API_KEY=
CALCOM_EVENT_TYPE_ID=
# Optional overrides (defaults in src/config/settings.py):
# CALCOM_BASE_URL=
# CALCOM_API_VERSION=
# CALCOM_BOOKING_API_VERSION=

# Optional: TTS if you switch from Inworld
# CARTESIA_API_KEY=

# Optional: Postgres (e.g. after docker compose up)
# DATABASE_URL=postgresql+psycopg://postgres:postgres@localhost:5432/voice_portfolio

# Optional: R2 / S3 for session artifacts
# R2_ENDPOINT=
# R2_BUCKET=
# R2_ACCESS_KEY_ID=
# R2_SECRET_ACCESS_KEY=
